# Steffi Nossen Archive - Environment Configuration
# Copy this file to .env and fill in your values before deploying.
#
#   cp .env.example .env
#   nano .env

# ─── Domain ───────────────────────────────────────────────────────────
# The public domain name pointing to this server's static IP.
# Required for Let's Encrypt SSL certificates.
NEXTCLOUD_DOMAIN=archive.steffinossen.org

# ─── Data Directory ──────────────────────────────────────────────────
# Host path where Nextcloud stores all user data.
# Points to the RAID1 array. Do NOT change after initial setup.
NEXTCLOUD_DATADIR=/mnt/archive

# ─── Performance ─────────────────────────────────────────────────────
# PHP memory limit (default 512M is too low for preview generation)
NEXTCLOUD_MEMORY_LIMIT=2048M

# Max upload size (must accommodate large dance videos)
NEXTCLOUD_UPLOAD_LIMIT=16G

# Max PHP execution time in seconds (for large imports and indexing)
NEXTCLOUD_MAX_TIME=3600

# ─── Networking ──────────────────────────────────────────────────────
# Port for Nextcloud Talk STUN/TURN server
TALK_PORT=3478

# Apache listens on this port internally (Caddy proxies 443 → here)
APACHE_PORT=11000
APACHE_IP_BINDING=127.0.0.1

# ─── Backup ──────────────────────────────────────────────────────────
# Borg backup retention policy
BORG_RETENTION_POLICY="--keep-within=7d --keep-weekly=4 --keep-monthly=6"

# ─── Optional: Hardware Acceleration ─────────────────────────────────
# Uncomment if the server has /dev/dri (Intel/AMD integrated GPU).
# Helps with video transcoding in Memories/Go-VOD.
# NEXTCLOUD_ENABLE_DRI_DEVICE=true

# ─── Timezone ────────────────────────────────────────────────────────
TZ=America/New_York
