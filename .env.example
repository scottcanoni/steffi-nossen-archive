# Steffi Nossen Archive - Environment Configuration
# Copy this file to .env and fill in your values before deploying.
#
#   cp .env.example .env
#   nano .env

# ─── Immich Version ──────────────────────────────────────────────────
# Pin to a specific version (e.g., v2.1.0) or use "release" for latest stable.
IMMICH_VERSION=release

# ─── Domain ──────────────────────────────────────────────────────────
# The public domain name pointing to this server's static IP.
# Required for Let's Encrypt SSL certificates (production only).
IMMICH_DOMAIN=archive.steffinossen.org

# ─── Storage Locations ───────────────────────────────────────────────
# Where Immich stores uploaded photos and videos.
# Points to the RAID1 array or data HDD.
UPLOAD_LOCATION=/mnt/archive/immich-uploads

# Where existing photo folders live (for External Library feature).
# Mounted read-only into the Immich container.
EXTERNAL_LIBRARY=/mnt/archive/external

# Where PostgreSQL stores its data.
# Keep this on the SSD for performance.
DB_DATA_LOCATION=/mnt/archive/immich-db

# ─── Database ────────────────────────────────────────────────────────
# Use only A-Za-z0-9 characters for the password.
DB_PASSWORD=CHANGE_ME_TO_A_RANDOM_STRING
DB_USERNAME=postgres
DB_DATABASE_NAME=immich

# ─── Timezone ────────────────────────────────────────────────────────
TZ=America/New_York
